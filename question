✅ 3. Dockerize the Application
Create file: Dockerfile
Dockerfile
FROM nginx:alpine
COPY . /usr/share/nginx/html
Build & run:
Bash
docker build -t merch-app .
docker run -d -p 8080:80 merch-app
👉 Open in browser:
http://localhost:8080


✅ 4. Jenkins Pipeline (IMPORTANT for exam)
Create Jenkinsfile
Groovy
pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                git 'https://github.com/your-username/merch-store.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t merch-app .'
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker run -d -p 8080:80 merch-app'
            }
        }
    }
}


✅ 5. Kubernetes Deployment
Create: deployment.yaml
YAML
apiVersion: apps/v1
kind: Deployment
metadata:
  name: merch-deployment
spec:
  replicas: 2
  selector:
    matchLabels:
      app: merch
  template:
    metadata:
      labels:
        app: merch
    spec:
      containers:
      - name: merch-container
        image: merch-app
        ports:
        - containerPort: 80
Create: service.yaml
YAML
apiVersion: v1
kind: Service
metadata:
  name: merch-service
spec:
  type: NodePort
  selector:
    app: merch
  ports:
    - port: 80
      targetPort: 80
      nodePort: 30007
Run:
Bash
kubectl apply -f deployment.yaml
kubectl apply -f service.yaml
